{
  "name": "seapack-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4444 --mode preview --debug",
    "lint": "eslint src mock --fix",
    "lint:ci": "eslint src mock --cache --max-warnings 0",
    "typecheck": "vue-tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "reinstall": "node -e \"require('fs').rmSync('node_modules',{recursive:true,force:true})\" && pnpm install",
    "i": "pnpm install",
    "prepare": "husky"
  },
  "dependencies": {
    "@antv/x6": "^3.1.6",
    "@antv/x6-vue-shape": "^3.0.2",
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^10.9.0",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-vue": "^5.1.10",
    "axios": "^1.7.7",
    "cesium": "^1.119.0",
    "codemirror": "^5.0.2",
    "codemirror-editor-vue3": "^2.8.0",
    "echarts": "^5.5.1",
    "echarts-gl": "^2.0.9",
    "element-plus": "^2.6.1",
    "jsencrypt": "^3.5.4",
    "lodash-es": "^4.17.21",
    "markdown-it": "^14.1.1",
    "mitt": "^3.0.1",
    "nprogress": "^0.2.0",
    "ol": "^9.1.0",
    "path-browserify": "^1.0.1",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "seapack-f-o": "^1.0.3",
    "vue": "^3.5.13",
    "vue3-slide-verify": "^1.1.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.12.7",
    "@types/nprogress": "^0.2.3",
    "@types/ol": "^7.0.0",
    "@types/path-browserify": "^1.0.3",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "@unocss/eslint-config": "^0.65.2",
    "@unocss/preset-attributify": "^0.65.2",
    "@unocss/preset-icons": "^0.65.2",
    "@unocss/preset-legacy-compat": "^0.65.2",
    "@unocss/preset-rem-to-px": "^0.65.2",
    "@unocss/preset-uno": "^0.65.2",
    "@unocss/transformer-directives": "^0.65.2",
    "@unocss/transformer-variant-group": "^0.65.2",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/compiler-sfc": "^3.5.13",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "mockjs": "^1.1.0",
    "prettier": "^3.5.3",
    "sass": "^1.74.1",
    "typescript": "^5.2.2",
    "unocss": "^0.65.2",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-element-plus": "^0.8.0",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.4.19",
    "vite-plugin-cesium": "^1.2.23",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-mock": "^2.9.6",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-vue-devtools": "^7.0.27",
    "vue-i18n": "^9.12.1",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.0.6"
  },
  "lint-staged": {
    "*.{vue,js,ts,tsx,jsx}": [
      "eslint --fix"
    ],
    "*.{scss,css}": [
      "prettier --write"
    ]
  }
}
